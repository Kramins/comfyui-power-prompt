{
  "name": "power-prompt",
  "version": "0.1.2",
  "description": "ComfyUI Power Prompt node – editor build tooling",
  "private": true,
  "type": "module",
  "scripts": {
    "build-editor": "node scripts/build-editor-bundle.mjs",
    "build-node": "node scripts/build-node-bundle.mjs",
    "build": "npm run build-editor && npm run build-node",
    "release": "node scripts/release.mjs",
    "check-version": "node scripts/check-version.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.0.0",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/lang-yaml": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/lint": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/theme-one-dark": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "esbuild": "^0.25.0",
    "husky": "^9.1.7"
  }
}
